{
  "name": "canoe-scoreboard-v2",
  "private": true,
  "version": "3.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "c123-proxy": "node scripts/c123-proxy.js",
    "mock:tcp": "npx tsx scripts/mock-c123-tcp.ts",
    "mock:ws": "npx tsx scripts/mock-cli-ws.ts",
    "test:providers": "vitest run src/__tests__/provider-comparison.test.ts",
    "test:visual": "playwright test cli-vs-c123.spec.ts --project=vertical"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "ws": "^8.20.0"
  }
}
